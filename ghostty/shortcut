# splits
keybind = alt+up=new_split:up
keybind = alt+down=new_split:down
keybind = alt+left=new_split:left
keybind = alt+right=new_split:right

keybind = shift+up=goto_split:up
keybind = shift+down=goto_split:down
keybind = shift+left=goto_split:left
keybind = shift+right=goto_split:right

keybind = shift+enter=toggle_split_zoom

# ghostt +list-keybinds
# keybind para fullscreen: ctrl+enter

# tab

keybind = alt+'=new_tab
keybind = ctrl+shift+tab=toggle_tab_overview
keybind = shift+'=close_tab
